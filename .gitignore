# Dependencies
node_modules/

# Environment files (contain secrets)
.env
*.env.local

# Unified config (contains rpcToken, HA token, etc.)
roboframe.config.json

# Database files
*.duckdb
*.duckdb.wal

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
.claude/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Local data store: blocked posts/tags + tag list catalog. Single
# hand-editable JSON file, per-install, never committed.
imagemirror/data.json

# Device telemetry sink (reportMetrics / reportLog). Append-only JSONL,
# rotated at ~5 MB; per-install machine output, never committed.
imagemirror/telemetry.jsonl
imagemirror/telemetry.jsonl.1

# User-supplied HTML pages shown by /custom_page (P key "custom page" mode).
# Per-install, never committed.
imagemirror/custom_pages/

# On-demand H.264 transcodes served by /get?vcodec=h264. Per-install cache.
imagemirror/video_cache/

# Build artifacts
dist/
build/

# Python bytecode (native-kiosk)
__pycache__/
*.pyc
