<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Request History</title>
    <style>
      :root{
        --gap:12px;
        --bg:#000000;
        --surface:#121212;
        --text:#f4f4f4;
        --muted:#d2d2d2;
        --border:#3a3a3a;
        --save:#ff6b6b;
        --save-hover:#ff8383;
        --save-text:#1a0000;
        --view:#d4d7dd;
        --view-hover:#e3e6eb;
        --view-text:#111111;
      }
      html,body{height:100%;margin:0;font-family:Arial,Helvetica,sans-serif;background:var(--bg);color:var(--text)}
      .container{padding:16px;box-sizing:border-box}
      h1{margin:0 0 12px}

      .display{margin:0 0 28px}
      .display h2{margin:0 0 10px;font-size:18px;display:flex;align-items:baseline;gap:8px}
      .display h2 .count{font-size:13px;font-weight:400;color:var(--muted)}
      .card.hidden{display:none}
      .expand{margin-top:12px}

      .grid{
        display:grid;
        grid-template-columns:repeat(auto-fill,minmax(160px,1fr));
        gap:var(--gap);
      }

      .card{
        background:var(--surface);border:1px solid var(--border);padding:8px;display:flex;flex-direction:column;align-items:center;gap:8px;border-radius:8px;
      }

      .thumb{
        width:100%;height:0;padding-bottom:100%;position:relative;overflow:hidden;border-radius:6px;background:#0a0a0a;
      }
      .thumb img,.thumb video{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;cursor:pointer;opacity:0;transition:opacity .3s}
      .thumb img.loaded,.thumb video.loaded{opacity:1}
      .thumb .spinner{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:13px}
      /* Play badge over a video's first-frame preview. pointer-events:none so
         clicks fall through to the thumb (opens the fullscreen player). */
      .thumb .play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;opacity:0;transition:opacity .3s}
      .thumb .play.loaded{opacity:1}
      .thumb .play::before{content:"";width:44px;height:44px;border-radius:50%;background:rgba(0,0,0,0.55);box-shadow:0 0 0 1px rgba(255,255,255,0.25)}
      .thumb .play::after{content:"";position:absolute;border-style:solid;border-width:9px 0 9px 15px;border-color:transparent transparent transparent #fff;margin-left:4px}

      .meta{width:100%;display:flex;justify-content:space-between;flex-flow: column;align-items:center;font-size:13px;color:var(--muted)}
      .meta .id{font-weight:600;color:var(--text)}

      .btn{appearance:none;border:1px solid transparent;padding:6px 10px;background:var(--save);color:var(--save-text);border-radius:6px;cursor:pointer;font-weight:600}
      .btn:not(:disabled):hover{background:var(--save-hover)}
      .btn.secondary{background:var(--view);color:var(--view-text);border-color:#b9c0c9}
      .btn.secondary:not(:disabled):hover{background:var(--view-hover)}
      .btn.block{background:transparent;color:var(--muted);border-color:var(--border)}
      .btn.block:not(:disabled):hover{background:#2a1010;color:#ff8383;border-color:#ff8383}
      .btn:disabled{opacity:0.75;cursor:not-allowed}
      .btn:focus-visible{outline:2px solid #ffffff;outline-offset:2px}

      .viewer{position:fixed;inset:0;background:rgba(0,0,0,0.95);display:none;align-items:center;justify-content:center;z-index:9999}
      .viewer.visible{display:flex}
      .viewer img,.viewer video{max-width:100%;max-height:100%;height:100%;object-fit:contain}
      .viewer img[hidden],.viewer video[hidden]{display:none}

      @media (max-width:640px){
        .grid{grid-template-columns:repeat(auto-fill,minmax(120px,1fr))}
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Request History</h1>

      <% if (!groups || groups.length === 0) { %>
        <p>No recent requests</p>
      <% } else { %>
        <% groups.forEach(function(group){ %>
          <section class="display">
            <h2><%= group.deviceId %> <span class="count"><%= group.posts.length %> item<%= group.posts.length === 1 ? '' : 's' %></span></h2>
            <div class="grid">
              <% group.posts.forEach(function(post, i){ %>
                <% var isVideo = /^(webm|mp4)$/i.test(post.ext || ''); %>
                <div class="card<%= i >= visible ? ' hidden' : '' %>" data-id="<%= post.id %>"<%= isVideo ? ' data-video="1"' : '' %>>
                  <div class="thumb">
                    <div class="spinner">Loading…</div>
                    <% if (isVideo) { %>
                      <video alt="Preview <%= post.id %>" muted playsinline preload="metadata"></video>
                      <div class="play" aria-hidden="true"></div>
                    <% } else { %>
                      <img alt="Preview <%= post.id %>" />
                    <% } %>
                  </div>
                  <div class="meta">
                    <div class="id">ID <%= post.id %></div>
                    <div>
                      <button class="btn save">Save</button>
                      <button class="btn secondary view">View</button>
                      <button class="btn block">Block</button>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
            <% if (group.posts.length > visible) { %>
              <button class="btn secondary expand" data-expand>Show <%= group.posts.length - visible %> more</button>
            <% } %>
          </section>
        <% }) %>
      <% } %>
    </div>

    <div class="viewer" id="viewer" aria-hidden="true">
      <img id="viewerImg" src="" alt="Full size preview" />
      <video id="viewerVideo" playsinline controls loop hidden></video>
    </div>

    <script>
      const TOKEN = <%- JSON.stringify(token || '') %>;
      const LOWMEM = <%- JSON.stringify(Number(lowmem) === 1 ? 1 : 0) %>;
      const tokenParam = TOKEN ? '&token=' + encodeURIComponent(TOKEN) : '';
      // Resolve sibling endpoints relative to this page so reverse-proxy
      // subpaths (e.g. /myslideshow/history) keep working.
      const BASE = new URL('./', window.location.href);
      const endpoint = (name, query) => new URL(name + '?' + query, BASE).toString();

      // Streaming URL for a video post. Videos bypass the sharp pipeline —
      // /get streams the raw file with Range support, so convert/width/lowmem
      // are ignored; record=0 keeps history views from re-recording.
      const videoUrl = (id) => endpoint('get', 'id=' + encodeURIComponent(id) + '&record=0' + tokenParam);

      // Fetch a card's preview once. Hidden cards (beyond the per-display
      // visible window) aren't loaded until their Expand button reveals them,
      // so the initial page only fires HISTORY_VISIBLE fetches per display.
      // Video cards get a first-frame preview: preload only metadata, then
      // seek to the first frame so the browser paints it without pulling the
      // whole clip (the seek fetches just the head via a Range request).
      function loadCard(card) {
        const spinner = card.querySelector('.thumb .spinner');

        if (card.dataset.video) {
          const video = card.querySelector('.thumb video');
          if (!video || video.dataset.loaded) return;
          video.dataset.loaded = '1';
          const badge = card.querySelector('.thumb .play');
          const reveal = () => {
            video.classList.add('loaded');
            if (badge) badge.classList.add('loaded');
            if (spinner) spinner.remove();
          };
          // Some browsers paint the first frame on loadeddata; others only
          // after an explicit seek. Do both — reveal on whichever lands first.
          video.onloadedmetadata = () => { try { video.currentTime = 0.1; } catch (_) {} };
          video.onloadeddata = reveal;
          video.onseeked = reveal;
          video.onerror = () => { if (spinner) spinner.textContent = 'Failed'; };
          video.src = videoUrl(card.dataset.id);
          return;
        }

        const img = card.querySelector('.thumb img');
        if (!img || img.dataset.loaded) return;
        img.dataset.loaded = '1';
        img.onload = () => { img.classList.add('loaded'); if (spinner) spinner.remove(); };
        img.onerror = () => { if (spinner) spinner.textContent = 'Failed'; };
        img.src = endpoint('get', 'id=' + encodeURIComponent(card.dataset.id) + '&convert=1&bright=0&width=640&height=480&record=0&lowmem=' + LOWMEM + tokenParam);
      }

      document.querySelectorAll('.card[data-id]:not(.hidden)').forEach(loadCard);

      document.addEventListener('click', async (ev) => {
        const expand = ev.target.closest('[data-expand]');
        if (expand) {
          const section = expand.closest('.display');
          section.querySelectorAll('.card.hidden').forEach((c) => { c.classList.remove('hidden'); loadCard(c); });
          expand.remove();
          return;
        }

        const btn = ev.target.closest('.btn');
        const cardFromBtn = btn ? btn.closest('.card') : null;
        const thumb = ev.target.closest('.thumb');
        const cardFromThumb = thumb ? thumb.closest('.card') : null;
        const card = cardFromBtn || cardFromThumb;
        if (!card) return;
        const id = card.dataset.id;

        if (btn && btn.classList.contains('save')) {
          btn.disabled = true;
          const originalText = btn.textContent;
          btn.textContent = 'Saving...';
          try {
            const resp = await fetch(endpoint('save', 'id=' + encodeURIComponent(id) + tokenParam), { method: 'GET' });
            if (!resp.ok) throw new Error('Save failed');
            btn.textContent = 'Saved';
            setTimeout(() => { btn.textContent = originalText; btn.disabled = false; }, 1500);
          } catch (err) {
            console.error(err);
            btn.textContent = 'Error';
            setTimeout(() => { btn.textContent = originalText; btn.disabled = false; }, 1500);
          }
          return;
        }

        if (btn && btn.classList.contains('block')) {
          btn.disabled = true;
          const originalText = btn.textContent;
          btn.textContent = 'Blocking...';
          try {
            const resp = await fetch(endpoint('block', 'id=' + encodeURIComponent(id) + tokenParam), { method: 'GET' });
            if (!resp.ok) throw new Error('Block failed');
            // Drop every card for this id across all displays — the post is
            // now server-side blocked and won't be served again.
            document.querySelectorAll('.card[data-id="' + CSS.escape(id) + '"]').forEach((c) => c.remove());
          } catch (err) {
            console.error(err);
            btn.textContent = 'Error';
            setTimeout(() => { btn.textContent = originalText; btn.disabled = false; }, 1500);
          }
          return;
        }

        if ((btn && btn.classList.contains('view')) || (!btn && cardFromThumb)) {
          const viewer = document.getElementById('viewer');
          const viewerImg = document.getElementById('viewerImg');
          const viewerVideo = document.getElementById('viewerVideo');
          if (!viewer) return;
          if (card.dataset.video) {
            // Play the clip full-screen from its own streaming URL rather than
            // reusing the preview element (which is seeked to the first frame).
            viewerImg.hidden = true;
            viewerImg.src = '';
            viewerVideo.hidden = false;
            viewerVideo.src = videoUrl(id);
            viewerVideo.play().catch(() => {});
          } else {
            const img = card.querySelector('img');
            if (!img) return;
            viewerVideo.hidden = true;
            viewerVideo.removeAttribute('src');
            viewerVideo.load();
            viewerImg.hidden = false;
            viewerImg.src = img.src;
          }
          viewer.classList.add('visible');
          viewer.setAttribute('aria-hidden','false');
        }
      });

      document.getElementById('viewer').addEventListener('click', (e) => {
        const viewer = e.currentTarget;
        viewer.classList.remove('visible');
        viewer.setAttribute('aria-hidden','true');
        document.getElementById('viewerImg').src = '';
        const viewerVideo = document.getElementById('viewerVideo');
        viewerVideo.pause();
        viewerVideo.removeAttribute('src');
        viewerVideo.load();
      });
      // Keep clicks on the video controls (play/pause/scrub) from bubbling to
      // the backdrop and closing the viewer — dismiss with the backdrop or Esc.
      document.getElementById('viewerVideo').addEventListener('click', (e) => e.stopPropagation());
      window.addEventListener('keydown', (e) => { if (e.key === 'Escape') document.getElementById('viewer').click(); });
    </script>
  </body>
</html>
